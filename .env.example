# ContextOS environment template.
#
# Copy this file to `.env` in the repository root and fill in the values you
# need:
#
#     cp .env.example .env
#
# The API server (`pnpm --filter @workspace/api-server run dev`) and the
# database/maintenance commands (`seed`, `clear`, `push`, `push-prod`) load this
# file automatically. `.env` is gitignored — never commit real secret values.
#
# Variables already present in the environment ALWAYS take precedence over this
# file, so platform-injected secrets (e.g. Replit's Secrets pane) are never
# overridden. On Replit you typically do not need a `.env` at all.

# ============================================================================
# REQUIRED to run an agent (the two-step Quickstart):
#   1. DATABASE_URL below
#   2. exactly ONE model-provider key (see "Model provider key" section)
# Everything else in this file is optional.
# ============================================================================

# --- Required: database -----------------------------------------------------

# Postgres connection string. The API server and the db commands will not start
# without it. On Replit this is provided automatically.
DATABASE_URL=postgresql://user:password@host:5432/contextos

# --- Required: ONE model provider key ---------------------------------------
#
# Set exactly one of these to give the bot a model. On startup the server
# auto-provisions the bot's model endpoint from the highest-precedence key
# present, in this order: OpenAI > Anthropic > Google > OpenRouter.
# (On Replit with none set, the keyless managed Anthropic endpoint is used.)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Optional: additional model provider keys -------------------------------
#
# Only needed if you add endpoints for these providers from the UI; an env var
# here acts as the fallback key for that provider.
AZURE_OPENAI_API_KEY=
OPENAI_COMPATIBLE_API_KEY=

# --- Optional: server port --------------------------------------------------

# Port the API server listens on (defaults to 8080). Replit and most hosts
# inject this automatically; set it yourself only for a local/GitHub-clone run.
PORT=8080

# --- Optional: channels & web tools -----------------------------------------

# Telegram bot channel. Leave empty to disable the Telegram integration.
TELEGRAM_BOT_TOKEN=
# Public https URL for the Telegram webhook (e.g.
# https://<your-host>/api/telegram/webhook). When set together with
# TELEGRAM_BOT_TOKEN, the webhook is registered automatically on boot. For a
# local tunnel, pin TUNNEL_SUBDOMAIN below first, then set this to
# https://<subdomain>.loca.lt/api/telegram/webhook so it survives restarts.
TELEGRAM_WEBHOOK_URL=

# Auto public tunnel. On a local (non-Replit) run, when a bot token is set,
# `./run.sh` opens a public tunnel and registers it as the Telegram webhook
# automatically. Set to 0/false/no/off to disable.
ENABLE_TUNNEL=
# Tunnel backend: `localtunnel` (default) or `cloudflared`.
#   localtunnel — bundled, no account, but loca.lt may serve a one-time browser
#     reminder page and occasionally drops connections.
#   cloudflared — Cloudflare quick tunnel (valid TLS, no account, more reliable);
#     requires the `cloudflared` binary on PATH. Assigns a random
#     https://<random>.trycloudflare.com URL (TUNNEL_SUBDOMAIN is ignored).
TUNNEL_PROVIDER=
# Request a fixed loca.lt subdomain so the tunnel URL is stable across restarts
# (https://<subdomain>.loca.lt); `./run.sh` re-requests it on every run. Left
# empty, loca.lt assigns a random one. localtunnel only.
TUNNEL_SUBDOMAIN=
# localtunnel server host (defaults to https://localtunnel.me). localtunnel only.
TUNNEL_HOST=

# Firecrawl (web fetch/scrape tool). Leave empty to disable web tools.
FIRECRAWL_API_KEY=
# Override the Firecrawl API base URL (defaults to Firecrawl's hosted API).
FIRECRAWL_API_BASE=

# --- Optional: operational --------------------------------------------------

# Filesystem path for the local model-key secret store.
MODEL_SECRET_STORE_PATH=

# Directory of the built web UI for the API server to serve at its root (the
# single-URL mode). Normally set automatically by `./run.sh`; leave empty unless
# you serve a custom build path. On Replit this stays empty (the web is a
# separate artifact).
CONTEXTOS_WEB_DIR=

# Log verbosity (e.g. debug, info, warn, error).
LOG_LEVEL=

# Runtime mode. Usually set by the start command, not here.
NODE_ENV=

# Set to 1 to skip the automatic database schema apply on boot (development).
CONTEXTOS_SKIP_DB_PUSH=
